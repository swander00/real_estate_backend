# =============================================================================
# Real Estate Backend - Complete Environment Configuration Template
# =============================================================================

# =============================================================================
# CORE APPLICATION SETTINGS
# =============================================================================
NODE_ENV=development
PORT=3000
APP_VERSION=2.0.0
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# =============================================================================
# DATABASE CONFIGURATION (Supabase)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database connection pooling
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=2
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=60000
DB_QUERY_TIMEOUT=30000
DB_BATCH_SIZE=100

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
JWT_SECRET=your-super-secure-jwt-secret-key-at-least-32-characters-long
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
API_KEY_SECRET=your-api-key-secret

# =============================================================================
# CACHING (Redis)
# =============================================================================
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300

# =============================================================================
# EXTERNAL APIs (IDX & VOW)
# =============================================================================
IDX_API_URL=https://idx-api.example.com
IDX_API_KEY=your-idx-api-key
IDX_FREEHOLD_URL=https://idx-api.example.com/freehold
IDX_CONDO_URL=https://idx-api.example.com/condo
IDX_LEASE_URL=https://idx-api.example.com/lease
IDX_MEDIA_URL=https://idx-api.example.com/media
IDX_OPENHOUSE_URL=https://idx-api.example.com/openhouse
IDX_ROOMS_URL=https://idx-api.example.com/rooms

VOW_API_URL=https://vow-api.example.com
VOW_API_KEY=your-vow-api-key
VOW_FREEHOLD_URL=https://vow-api.example.com/freehold
VOW_CONDO_URL=https://vow-api.example.com/condo
VOW_LEASE_URL=https://vow-api.example.com/lease
VOW_MEDIA_URL=https://vow-api.example.com/media
VOW_OPENHOUSE_URL=https://vow-api.example.com/openhouse
VOW_ROOMS_URL=https://vow-api.example.com/rooms

# =============================================================================
# OAUTH2 PROVIDERS
# =============================================================================
# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft OAuth2
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# GitHub OAuth2
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# =============================================================================
# CDN CONFIGURATION
# =============================================================================
# Cloudflare
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id
CLOUDFLARE_CDN_DOMAIN=your-domain.com

# AWS CloudFront
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_CLOUDFRONT_DISTRIBUTION_ID=your-distribution-id
AWS_CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net

# KeyCDN
KEYCDN_API_KEY=your-keycdn-api-key
KEYCDN_ZONE_ID=your-keycdn-zone-id
KEYCDN_DOMAIN=your-keycdn-domain.kxcdn.com

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false
RATE_LIMIT_SKIP_FAILED_REQUESTS=false

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# Alerting thresholds
ALERT_ERROR_RATE_HIGH=10
ALERT_ERROR_RATE_CRITICAL=20
ALERT_RESPONSE_TIME_HIGH=5000
ALERT_RESPONSE_TIME_CRITICAL=10000
ALERT_RATE_LIMIT_HIGH=80
ALERT_RATE_LIMIT_CRITICAL=95

# Performance monitoring
SLOW_REQUEST_THRESHOLD=5000
HIGH_MEMORY_THRESHOLD=10485760
SLOW_DATABASE_THRESHOLD=1000

# Security monitoring
SECURITY_MONITORING_ENABLED=true
SECURITY_RATE_LIMIT_THRESHOLD=100
SECURITY_IP_WHITELIST=
SECURITY_IP_BLACKLIST=

# Dashboard configuration
DASHBOARD_ENABLED=true
DASHBOARD_REFRESH_INTERVAL=30000
DASHBOARD_MAX_ALERTS=50
DASHBOARD_MAX_METRICS_HISTORY=100

# =============================================================================
# EXTERNAL MONITORING SERVICES
# =============================================================================
# Slack notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook

# Email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_TO=admin@yourdomain.com

# Webhook notifications
WEBHOOK_URL=https://your-webhook-endpoint.com/notifications
WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
# Vercel
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id

# Docker
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_NAME=your-username/real-estate-backend

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================
# Test database (optional)
TEST_SUPABASE_URL=https://your-test-project.supabase.co
TEST_SUPABASE_ANON_KEY=your-test-anon-key
TEST_SUPABASE_SERVICE_ROLE_KEY=your-test-service-role-key

# Test Redis (optional)
TEST_REDIS_URL=redis://localhost:6380

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_OAUTH2=true
ENABLE_CDN=true
ENABLE_MONITORING=true
ENABLE_CACHING=true
ENABLE_RATE_LIMITING=true
ENABLE_SECURITY_MONITORING=true

# =============================================================================
# ADVANCED CONFIGURATION
# =============================================================================
# CORS settings
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com
CORS_CREDENTIALS=true

# Helmet security settings
HELMET_CONTENT_SECURITY_POLICY=true
HELMET_HSTS_ENABLED=true

# Compression settings
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6

# Session settings (if using sessions)
SESSION_SECRET=your-session-secret
SESSION_MAX_AGE=86400000

# =============================================================================
# BACKUP & RECOVERY
# =============================================================================
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_REGION=us-east-1

# =============================================================================
# ANALYTICS & TRACKING
# =============================================================================
# Google Analytics
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# Mixpanel
MIXPANEL_TOKEN=your-mixpanel-token

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================
# Stripe (for payments)
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# SendGrid (for emails)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Twilio (for SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# NOTES
# =============================================================================
# 1. Copy this file to .env and fill in your actual values
# 2. Never commit .env files to version control
# 3. Use different values for development, staging, and production
# 4. Rotate secrets regularly
# 5. Use environment-specific configurations
# 6. Test all integrations in a staging environment first
