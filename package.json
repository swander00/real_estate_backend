{
  "name": "real-estate-backend",
  "version": "2.0.0",
  "description": "RESO Web API 2.0.0 compliant real estate backend with advanced MLS data synchronization",
  "type": "module",
  "keywords": [
    "real-estate",
    "reso",
    "mls",
    "property-data",
    "odata",
    "web-api",
    "supabase",
    "vercel"
  ],
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "dev:local": "node server.js",
    "deploy": "vercel --prod",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "test:performance": "jest tests/performance",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test-sync": "node lib/syncListingsIdx.js --test",
    "test-vow": "node lib/syncListingsVow.js --test",
    "full-sync": "node lib/syncListingsIdx.js",
    "incremental-sync": "node lib/syncListingsIdx.js --incremental",
    "test:env": "node api/test-env-local.js",
    "validate:reso": "node scripts/validateResoCompliance.js",
    "docs:generate": "node scripts/generateApiDocs.js",
    "backfill": "node scripts/backfill.js",
    "sync": "node scripts/sync-cli.js",
    "test-monitoring": "node test-monitoring.js",
    "monitor:health": "curl -s http://localhost:3000/health | jq",
    "monitor:metrics": "curl -s http://localhost:3000/health/metrics | jq",
    "monitor:alerts": "curl -s http://localhost:3000/health/alerts | jq",
    "monitor:dashboard": "echo 'Dashboard available at: http://localhost:3000/dashboard.html'",
    "lint": "eslint api/ lib/ mappers/ tests/",
    "lint:fix": "eslint api/ lib/ mappers/ tests/ --fix",
    "format": "prettier --write api/ lib/ mappers/ tests/",
    "docs": "node scripts/generateApiDocs.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.42.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "winston": "^3.11.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-sonar-reporter": "^2.0.0",
    "jest-watch-typeahead": "^2.2.2",
    "nodemon": "^3.0.0",
    "prettier": "^3.0.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/swander00/real_estate_backend.git"
  },
  "reso": {
    "version": "2.0.0",
    "compliance": {
      "web_api": true,
      "metadata": true,
      "odata_queries": true,
      "standard_resources": [
        "Property",
        "Media",
        "OpenHouse"
      ],
      "validation": true
    },
    "endpoints": {
      "root": "/api/reso",
      "metadata": "/api/reso/$metadata",
      "property": "/api/reso/Property",
      "media": "/api/reso/Media",
      "openhouse": "/api/reso/OpenHouse"
    }
  }
}
