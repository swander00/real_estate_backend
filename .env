# =============================================================================
# IDX DATA SOURCE URLS (Available/Active Listings Only)
# =============================================================================
# Main IDX endpoint
IDX_URL=https://query.ampre.ca/odata/Property?$filter=PropertyType ne 'Commercial' and ContractStatus eq 'Available'&$orderby=ModificationTimestamp desc

# IDX Property Type URLs
IDX_FREEHOLD_URL=https://query.ampre.ca/odata/Property?$filter=PropertyType eq 'Residential Freehold' and ContractStatus eq 'Available'&$orderby=ModificationTimestamp desc
IDX_CONDO_URL=https://query.ampre.ca/odata/Property?$filter=PropertyType ne 'Commercial' and PropertyType ne 'Residential Freehold' and ContractStatus eq 'Available' and TransactionType ne 'For Lease'&$orderby=ModificationTimestamp desc
IDX_LEASE_URL=https://query.ampre.ca/odata/Property?$filter=TransactionType eq 'For Lease' and PropertyType ne 'Commercial' and ContractStatus eq 'Available'&$orderby=ModificationTimestamp desc

# IDX Related Resources (IDX only, no VOW needed)
IDX_OPENHOUSE_URL=https://query.ampre.ca/odata/OpenHouse?$filter=OpenHouseDate ne null and OpenHouseStatus eq 'Active'&$orderby=ModificationTimestamp desc
IDX_ROOMS_URL=https://query.ampre.ca/odata/PropertyRooms?$orderby=ModificationTimestamp desc
IDX_MEDIA_URL=https://query.ampre.ca/odata/Media?$orderby=ModificationTimestamp desc

# =============================================================================
# VOW DATA SOURCE URLS (Sold/Expired Listings Only)
# =============================================================================
# Main VOW endpoint
VOW_URL=https://query.ampre.ca/odata/Property?$filter=PropertyType ne 'Commercial' and ContractStatus ne 'Available' and ModificationTimestamp ge 2025-01-01T00:00:00Z&$orderby=ModificationTimestamp desc

# VOW Property Type URLs
VOW_FREEHOLD_URL=https://query.ampre.ca/odata/Property?$filter=PropertyType eq 'Residential Freehold' and ContractStatus ne 'Available' and ModificationTimestamp ge 2021-01-01T00:00:00Z&$orderby=ModificationTimestamp desc
VOW_CONDO_URL=https://query.ampre.ca/odata/Property?$filter=PropertyType ne 'Commercial' and PropertyType ne 'Residential Freehold' and ContractStatus ne 'Available' and TransactionType ne 'For Lease' and ModificationTimestamp ge 2021-01-01T00:00:00Z&$orderby=ModificationTimestamp desc
VOW_LEASE_URL=https://query.ampre.ca/odata/Property?$filter=TransactionType eq 'For Lease' and PropertyType ne 'Commercial' and ContractStatus ne 'Available' and ModificationTimestamp ge 2021-01-01T00:00:00Z&$orderby=ModificationTimestamp desc

# VOW Media (may have different endpoint or same with filter)
VOW_MEDIA_URL=https://query.ampre.ca/odata/Media?$orderby=ModificationTimestamp desc

