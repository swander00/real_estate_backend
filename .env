# =============================================================================
# MLS DATA SOURCE URLS
# =============================================================================

# Primary Property Endpoints
IDX_URL=https://query.ampre.ca/odata/Property?$filter=PropertyType ne 'Commercial' and ContractStatus eq 'Available'&$orderby=ModificationTimestamp desc
VOW_URL=https://query.ampre.ca/odata/Property?$filter=PropertyType ne 'Commercial' and ContractStatus ne 'Available' and ModificationTimestamp ge 2024-01-01T00:00:00Z&$orderby=ModificationTimestamp desc


# Property Type Specific Endpoints
FREEHOLD_URL=https://query.ampre.ca/odata/Property?$filter=PropertyType eq 'Residential Freehold'&$orderby=ModificationTimestamp desc
CONDO_URL=https://query.ampre.ca/odata/Property?$filter=PropertyType ne 'Commercial' and PropertyType ne 'Residential Freehold'&$orderby=ModificationTimestamp desc
LEASE_URL=https://query.ampre.ca/odata/Property?$filter=TransactionType eq 'For Lease' and PropertyType ne 'Commercial'&$orderby=ModificationTimestamp desc

# Related Resource Endpoints
OPENHOUSE_URL=https://query.ampre.ca/odata/OpenHouse?$filter=OpenHouseDate ne null and OpenHouseStatus eq 'Active'&$orderby=ModificationTimestamp desc
ROOMS_URL=https://query.ampre.ca/odata/PropertyRooms?$orderby=ModificationTimestamp desc
MEDIA_URL=https://query.ampre.ca/odata/Media?$orderby=ModificationTimestamp desc

