# Monitoring and Alerting Configuration
# Copy this to your .env file and configure as needed

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_ENABLED=true
LOG_FILE_PATH=logs/
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=5
LOG_CONSOLE_ENABLED=true
LOG_CONSOLE_COLORIZE=true

# Metrics Configuration
METRICS_COLLECTION_INTERVAL=30000
METRICS_RETENTION_PERIOD=86400000
METRICS_MAX_RESPONSE_TIME_SAMPLES=100
METRICS_MAX_EXTERNAL_API_SAMPLES=50

# Health Check Configuration
HEALTH_CHECK_BASIC_ENABLED=true
HEALTH_CHECK_BASIC_INTERVAL=30000
HEALTH_CHECK_DATABASE_ENABLED=true
HEALTH_CHECK_DATABASE_INTERVAL=60000
HEALTH_CHECK_DATABASE_TIMEOUT=5000
HEALTH_CHECK_EXTERNAL_ENABLED=true
HEALTH_CHECK_EXTERNAL_INTERVAL=120000
HEALTH_CHECK_EXTERNAL_TIMEOUT=10000

# Alerting Configuration
ALERTING_ENABLED=true

# Console Alerts
ALERT_CONSOLE_ENABLED=true

# Webhook Alerts (Slack, Discord, etc.)
ALERT_WEBHOOK_ENABLED=false
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
ALERT_WEBHOOK_TIMEOUT=5000
ALERT_WEBHOOK_RETRIES=3

# Email Alerts
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SECURE=false
ALERT_EMAIL_FROM=alerts@your-domain.com
ALERT_EMAIL_TO=admin@your-domain.com,devops@your-domain.com
ALERT_EMAIL_SUBJECT=🚨 Real Estate Backend Alert

# Alert Thresholds
ALERT_ERROR_RATE_CRITICAL=5.0
ALERT_ERROR_RATE_HIGH=2.0
ALERT_ERROR_RATE_MEDIUM=1.0

ALERT_RESPONSE_TIME_CRITICAL=2000
ALERT_RESPONSE_TIME_HIGH=1000
ALERT_RESPONSE_TIME_MEDIUM=500

ALERT_MEMORY_CRITICAL=90
ALERT_MEMORY_HIGH=80
ALERT_MEMORY_MEDIUM=70

ALERT_DB_ERRORS_CRITICAL=10
ALERT_DB_ERRORS_HIGH=5
ALERT_DB_ERRORS_MEDIUM=2

ALERT_EXTERNAL_API_ERRORS_CRITICAL=20
ALERT_EXTERNAL_API_ERRORS_HIGH=10
ALERT_EXTERNAL_API_ERRORS_MEDIUM=5

# Alert Cooldown Periods (in milliseconds)
ALERT_COOLDOWN_CRITICAL=300000
ALERT_COOLDOWN_HIGH=600000
ALERT_COOLDOWN_MEDIUM=1800000
ALERT_COOLDOWN_LOW=3600000

# Alert Rate Limits (per hour)
ALERT_RATE_LIMIT_CRITICAL=10
ALERT_RATE_LIMIT_HIGH=20
ALERT_RATE_LIMIT_MEDIUM=50
ALERT_RATE_LIMIT_LOW=100

# Performance Monitoring
SLOW_REQUEST_THRESHOLD=5000
HIGH_MEMORY_THRESHOLD=10485760
SLOW_DATABASE_THRESHOLD=1000

# Security Monitoring
SECURITY_MONITORING_ENABLED=true
SECURITY_RATE_LIMIT_THRESHOLD=100
SECURITY_IP_WHITELIST=
SECURITY_IP_BLACKLIST=

# Dashboard Configuration
DASHBOARD_ENABLED=true
DASHBOARD_REFRESH_INTERVAL=30000
DASHBOARD_MAX_ALERTS=50
DASHBOARD_MAX_METRICS_HISTORY=100

# External Monitoring Services
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090
PROMETHEUS_PATH=/metrics

GRAFANA_ENABLED=false
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=your-grafana-api-key

DATADOG_ENABLED=false
DATADOG_API_KEY=your-datadog-api-key
DATADOG_APP_KEY=your-datadog-app-key

NEWRELIC_ENABLED=false
NEWRELIC_LICENSE_KEY=your-newrelic-license-key
NEWRELIC_APP_NAME=real-estate-backend

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System is under maintenance. Please try again later.
MAINTENANCE_ALLOWED_PATHS=/health,/metrics
